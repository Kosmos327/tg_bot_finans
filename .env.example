# Google Sheets Spreadsheet ID (from the URL of your Google Sheet)
SPREADSHEET_ID=your_spreadsheet_id_here

# Google Service Account credentials JSON (paste the entire JSON as one line)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Server port
PORT=5000

# Set to True to use built-in demo data instead of Google Sheets
DEMO_MODE=True

# Flask debug mode
DEBUG=False
